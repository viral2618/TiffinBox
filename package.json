{
  "name": "tiffinlane",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "lint:check": "next lint",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true npm run build",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-categories": "tsx scripts/seed-categories.ts",
    "db:seed-shops": "tsx scripts/shop-seeder.ts",
    "db:create-shop": "tsx scripts/create-shop-seeder.ts",
    "db:create-multiple-shops": "tsx scripts/create-multiple-shops-seeder.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:delete-all": "tsx scripts/delete-all-data.ts",
    "db:fix-notifications": "tsx scripts/fix-notification-preferences.ts",
    "search:init": "node scripts/init-search.js",
    "clean": "rm -rf .next out node_modules/.cache",
    "postbuild": "node -e \"if(process.env.MEILI_SEARCH_URL && process.env.MEILI_SEARCH_API_KEY) { setTimeout(() => require('child_process').spawn('npm', ['run', 'search:init'], {stdio: 'inherit'}), 10000); } else { console.log('Meilisearch not configured, skipping search initialization'); }\" || true"
  },
